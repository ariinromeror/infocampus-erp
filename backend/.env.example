# InfoCampus ERP — Backend (.env.example)
# Copia este archivo como .env y completa los valores

# Base de datos PostgreSQL (Supabase)
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# JWT (genera una clave segura para producción)
SECRET_KEY_AUTH=tu_clave_secreta_muy_larga_y_aleatoria
ALGORITHM=HS256

# CORS (orígenes permitidos, separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# IA / Groq (opcional, para chatbot Eva)
GROQ_API_KEY=
