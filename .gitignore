# ============================================================
# .gitignore — InfoCampus ERP
# Coloca este archivo en la RAÍZ del repositorio
# ============================================================

# ── Secretos — NUNCA subir al repositorio ───────────────────
backend/.env
scripts_db/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/
env/
.env/

# ── Node / Frontend ─────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.local

# ── Supabase ─────────────────────────────────────────────────
supabase/.temp/
supabase/functions/.cache/

# ── IDE / OS ─────────────────────────────────────────────────
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
